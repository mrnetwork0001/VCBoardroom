# ============================================
# Virtual VC Boardroom — Environment Config
# ============================================
# Copy this file to .env and fill in your keys

# REQUIRED: OpenAI API Key (powers the AI agents)
OPENAI_API_KEY=your-openai-api-key-here

# OPTIONAL: Birdeye API Key (Solana on-chain data: holders, trades, liquidity)
# Free tier: https://docs.birdeye.so/ → sign up for free
BIRDEYE_API_KEY=

# OPTIONAL: LunarCrush API Key (social sentiment: mentions, galaxy score, bullish/bearish)
# Free tier: https://lunarcrush.com/developers → sign up for free
LUNARCRUSH_API_KEY=

# OPTIONAL: Override the default model
# MODEL_NAME=gpt-4o-mini

# OPTIONAL: Server port
# PORT=8000
